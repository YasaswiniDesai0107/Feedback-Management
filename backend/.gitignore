# .gitignore
# Specifies files/folders that Git should NEVER track or commit.

# ==============================
# Environment & Secrets
# ==============================
.env                  # contains DB passwords — NEVER commit this
*.env
.env.*

# ==============================
# Python
# ==============================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ==============================
# Virtual Environment
# ==============================
venv/
env/
.venv/
ENV/

# ==============================
# IDEs
# ==============================
.vscode/
.idea/
*.swp
*.swo

# ==============================
# OS Files
# ==============================
.DS_Store
Thumbs.db

# ==============================
# Logs
# ==============================
*.log
logs/
